{
  "files": {
    "ignoreUnknown": true,
    "ignore": [
      ".code-standards",
      ".model-farm-live",
      "ai/contract.json",
      "src/app/service-runtime.service.ts",
      "src/model/model-definition.service.ts",
      "src/model/model-registry.service.ts",
      "src/model/model.types.ts",
      "src/prediction/prediction.service.ts",
      "src/snapshot-feature/snapshot-feature-label.service.ts",
      "src/snapshot-feature/snapshot-feature-projector.service.ts",
      "src/trainer-state/trainer-state.service.ts",
      "src/training/training-orchestrator.service.ts",
      "test/model-registry.test.ts",
      "test/prediction.test.ts",
      "test/service-runtime.test.ts",
      "test/snapshot-feature-projector.test.ts"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 160
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "arrowParentheses": "always",
      "bracketSpacing": true
    }
  },
  "json": {
    "formatter": {
      "enabled": true
    }
  }
}
